{
  "name": "parakram-vps",
  "version": "3.0.0",
  "private": true,
  "description": "Parakram VPS — Windows VPS Management Dashboard",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx src/backend/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build && tsc -p tsconfig.node.json",
    "bundle": "node scripts/bundle-backend.mjs",
    "sea": "node scripts/build-sea.mjs",
    "dist": "npm run build && npm run bundle && npm run sea",
    "preview": "vite preview",
    "start": "node dist/backend/index.js"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-dropdown-menu": "^2.1.13",
    "@radix-ui/react-scroll-area": "^1.2.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "i18next": "^26.1.0",
    "lucide-react": "^0.510.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.6.2",
    "recharts": "^3.9.1",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^22.16.1",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
