{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/backend",
    "rootDir": "src/backend",
    "paths": { "@/*": ["./src/*"] },
    "baseUrl": "."
  },
  "include": ["src/backend"]
}
