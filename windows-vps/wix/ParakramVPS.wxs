<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Parakram VPS"
           Version="3.0.0"
           Manufacturer="Parakram"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Language="1033"
           Codepage="1252">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Parakram VPS is already installed."
                  Schedule="afterInstallValidate" />

    <Media Id="1" Cabinet="parakram.cab" EmbedCab="yes" CompressionLevel="high" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="ParakramVPS">
        <Directory Id="DASHBOARD_DIR" Name="dashboard">
          <Directory Id="FRONTEND_DIR" Name="frontend">
            <Directory Id="ASSETS_DIR" Name="assets" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutsDir" Name="Parakram VPS" />
    </StandardDirectory>

    <!-- ======== FILES ======== -->
    <ComponentGroup Id="DashboardFiles" Directory="DASHBOARD_DIR">
      <Component Id="C_Node" Guid="*">
        <File Id="NodeExe" Name="node.exe" Source="runtime\node.exe" KeyPath="yes" />
      </Component>
      <Component Id="C_Backend" Guid="*">
        <File Id="BackendBundle" Name="backend.cjs" Source="bundle\backend.cjs" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="Shortcuts" Directory="AppShortcutsDir">
      <Component Id="C_Shortcuts" Guid="*">
        <Shortcut Id="DashboardShortcut"
                  Name="Parakram VPS Dashboard"
                  Description="Open Parakram VPS Dashboard"
                  Target="[System64Folder]cmd.exe"
                  Arguments="/c start http://127.0.0.1:9876" />
        <Shortcut Id="UninstallShortcut"
                  Name="Uninstall Parakram VPS"
                  Description="Remove Parakram VPS"
                  Target="[System64Folder]msiexec.exe"
                  Arguments="/x [ProductCode]" />
        <RegistryValue Id="ShortcutReg"
                       Root="HKCU"
                       Key="Software\Parakram\VPS"
                       Name="installed"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ======== CUSTOM ACTIONS ======== -->
    <CustomAction Id="InstallComponents"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  Directory="DASHBOARD_DIR"
                  ExeCommand="cmd.exe /c sc create ParakramVPS binPath= node.exe backend.cjs start=auto DisplayName= &quot;Parakram VPS Dashboard&quot; &amp;&amp; sc description ParakramVPS &quot;Parakram VPS management dashboard.&quot; &amp;&amp; sc failure ParakramVPS reset=86400 actions= restart/5000/restart/10000/restart/30000 &amp;&amp; timeout /t 2 /nobreak &amp;&amp; sc start ParakramVPS &amp;&amp; netsh advfirewall firewall add rule name= &quot;Parakram VPS Dashboard&quot; dir=in action=allow protocol=TCP localport=9876 profile=any" />

    <CustomAction Id="RemoveComponents"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  Directory="DASHBOARD_DIR"
                  ExeCommand="cmd.exe /c sc stop ParakramVPS 2>nul &amp; sc delete ParakramVPS 2>nul &amp; netsh advfirewall firewall delete rule name= &quot;Parakram VPS Dashboard&quot; 2>nul" />

    <InstallExecuteSequence>
      <Custom Action="InstallComponents" Sequence="4501" Condition="NOT REMOVE" />
      <Custom Action="RemoveComponents" Sequence="3451" Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <!-- ======== FEATURES ======== -->
    <Feature Id="MainProduct" Title="Parakram VPS" Level="1">
      <ComponentGroupRef Id="DashboardFiles" />
      <ComponentGroupRef Id="AutoGeneratedFrontend" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

    <UI Id="ParakramUI" />
  </Package>
</Wix>
