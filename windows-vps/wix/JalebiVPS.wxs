<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Jalebi VPS"
           Version="3.0.0"
           Manufacturer="Parakram Technologies"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Language="1033"
           Codepage="1252">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Jalebi VPS is already installed."
                  Schedule="afterInstallValidate" />

    <Media Id="1" Cabinet="jalebi.cab" EmbedCab="yes" CompressionLevel="high" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="JalebiVPS">
        <Directory Id="DASHBOARD_DIR" Name="dashboard">
          <Directory Id="FRONTEND_DIR" Name="frontend">
            <Directory Id="ASSETS_DIR" Name="assets" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutsDir" Name="Jalebi VPS" />
    </StandardDirectory>

    <!-- ======== FILES ======== -->
    <ComponentGroup Id="DashboardFiles" Directory="DASHBOARD_DIR">
      <Component Id="C_Node" Guid="*">
        <File Id="NodeExe" Name="node.exe" Source="runtime\node.exe" KeyPath="yes" />
      </Component>
      <Component Id="C_Backend" Guid="*">
        <File Id="BackendBundle" Name="backend.cjs" Source="bundle\backend.cjs" KeyPath="yes" />
      </Component>
      <Component Id="C_WinSW" Guid="*">
        <File Id="WinSWExe" Name="JalebiVPS-svc.exe" Source="runtime\JalebiVPS-svc.exe" KeyPath="yes" />
      </Component>
      <Component Id="C_WinSWConfig" Guid="*">
        <File Id="WinSWXml" Name="JalebiVPS-svc.xml" Source="wix\JalebiVPS-svc.xml" KeyPath="yes" />
      </Component>
      <Component Id="C_InstallServiceScript" Guid="*">
        <File Id="InstallServicePs1" Name="install-service.ps1" Source="wix\install-service.ps1" KeyPath="yes" />
      </Component>
      <Component Id="C_UninstallServiceScript" Guid="*">
        <File Id="UninstallServicePs1" Name="uninstall-service.ps1" Source="wix\uninstall-service.ps1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ProvisioningFiles" Directory="INSTALLFOLDER">
      <Component Id="C_Cloudflared" Guid="*">
        <File Id="CloudflaredExe" Name="cloudflared.exe" Source="runtime\cloudflared.exe" KeyPath="yes" />
      </Component>
      <Component Id="C_ProvisionScript" Guid="*">
        <File Id="ProvisionPs1" Name="provision.ps1" Source="wix\provision.ps1" KeyPath="yes" />
      </Component>
      <Component Id="C_DeprovisionScript" Guid="*">
        <File Id="DeprovisionPs1" Name="deprovision.ps1" Source="wix\deprovision.ps1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="Shortcuts" Directory="AppShortcutsDir">
      <Component Id="C_Shortcuts" Guid="*">
        <Shortcut Id="DashboardShortcut"
                  Name="Jalebi VPS Dashboard"
                  Description="Open Jalebi VPS Dashboard"
                  Target="[System64Folder]cmd.exe"
                  Arguments="/c start http://127.0.0.1:9876" />
        <Shortcut Id="UninstallShortcut"
                  Name="Uninstall Jalebi VPS"
                  Description="Remove Jalebi VPS"
                  Target="[System64Folder]msiexec.exe"
                  Arguments="/x [ProductCode]" />
        <RegistryValue Id="ShortcutReg"
                       Root="HKCU"
                       Key="Software\Parakram\VPS"
                       Name="installed"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ======== CUSTOM ACTIONS ======== -->
    <CustomAction Id="InstallComponents"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  Directory="DASHBOARD_DIR"
                  ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -File install-service.ps1" />

    <CustomAction Id="RemoveComponents"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  Directory="DASHBOARD_DIR"
                  ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -File uninstall-service.ps1" />

    <CustomAction Id="ProvisionHost"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  Directory="INSTALLFOLDER"
                  ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -File provision.ps1" />

    <CustomAction Id="DeprovisionHost"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  Directory="INSTALLFOLDER"
                  ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -File deprovision.ps1" />

    <!-- Safety net: RemoveFiles can hit Access Denied on node.exe if the
         WinSW-wrapped process hasn't fully released its own executable's
         file handle yet (a short OS-level delay after process exit). When
         that happens mid-transaction it can leave a partial install
         directory behind. Retry a full delete a few times, scheduled after
         RemoveFiles/RemoveFolders so the OS has had time to catch up. Inline
         command (not a .ps1 component file) so there's nothing for
         RemoveFiles to have already deleted out from under it. -->
    <CustomAction Id="FinalCleanup"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  Directory="INSTALLFOLDER"
                  ExeCommand="powershell.exe -NoProfile -Command &quot;$d = (Get-Location).Path; for ($i=0; $i -lt 8; $i++) { if (-not (Test-Path $d)) { break }; Get-ChildItem $d -Force -ErrorAction SilentlyContinue | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue; Start-Sleep -Milliseconds 750 }; Set-Location $env:TEMP; for ($i=0; $i -lt 10; $i++) { if (-not (Test-Path $d)) { break }; Remove-Item $d -Force -ErrorAction SilentlyContinue; Start-Sleep -Milliseconds 500 }&quot;" />

    <InstallExecuteSequence>
      <Custom Action="InstallComponents" Sequence="4501" Condition="NOT REMOVE" />
      <Custom Action="ProvisionHost" Sequence="4502" Condition="NOT REMOVE" />
      <Custom Action="DeprovisionHost" Sequence="3450" Condition="REMOVE~=&quot;ALL&quot;" />
      <Custom Action="RemoveComponents" Sequence="3451" Condition="REMOVE~=&quot;ALL&quot;" />
      <Custom Action="FinalCleanup" Sequence="3601" Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <!-- ======== FEATURES ======== -->
    <Feature Id="MainProduct" Title="Jalebi VPS" Level="1">
      <ComponentGroupRef Id="DashboardFiles" />
      <ComponentGroupRef Id="ProvisioningFiles" />
      <ComponentGroupRef Id="AutoGeneratedFrontend" />
      <ComponentGroupRef Id="AutoGeneratedFrontendAssets" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

    <UI Id="JalebiUI" />
  </Package>
</Wix>
